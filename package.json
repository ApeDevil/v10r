{
	"name": "velociraptor",
	"private": true,
	"license": "MIT",
	"version": "0.0.1",
	"description": "Full-stack SvelteKit template focused on performance and lightweight deployment",
	"author": "ApeDevil (https://github.com/ApeDevil)",
	"repository": {
		"type": "git",
		"url": "https://gitlab.com/ApeDevil/v10r"
	},
	"keywords": [
		"sveltekit",
		"svelte5",
		"bun",
		"template",
		"drizzle",
		"unocss",
		"better-auth",
		"neon",
		"neo4j"
	],
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check-rs --tsconfig ./tsconfig.json --threshold error --ignore '**/3d/**' --ignore '**/EmbedSceneContent.svelte'",
		"check:watch": "svelte-kit sync && svelte-check-rs --tsconfig ./tsconfig.json --threshold error --ignore '**/3d/**' --ignore '**/EmbedSceneContent.svelte' --watch",
		"db:push": "bunx drizzle-kit push",
		"db:studio": "bunx drizzle-kit studio",
		"db:rag-pre": "bun run scripts/setup-rag.ts pre",
		"db:rag-post": "bun run scripts/setup-rag.ts post",
		"db:neo4j-setup": "bun run scripts/setup-neo4j.ts",
		"db:setup": "bun run db:rag-pre && bun run db:push && bun run db:rag-post && bun run db:neo4j-setup",
		"db:seed:llmwiki": "bun run scripts/seed-llmwiki.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"check:biome": "biome ci .",
		"test": "vitest run",
		"test:watch": "vitest",
		"i18n:check-missing": "bun run scripts/i18n/check-missing.ts",
		"validate": "bun run check && biome ci . && bun run test && bun run i18n:check-missing",
		"knip": "knip"
	},
	"dependencies": {
		"@ai-sdk/google": "^3.0.62",
		"@ai-sdk/groq": "^3.0.35",
		"@ai-sdk/openai": "^3.0.52",
		"@ai-sdk/svelte": "^3.0.0",
		"@aws-sdk/client-s3": "^3.700.0",
		"@aws-sdk/s3-request-presigner": "^3.700.0",
		"@fontsource-variable/fraunces": "^5.0.0",
		"@fontsource-variable/inter": "^5.0.0",
		"@fontsource-variable/jetbrains-mono": "^5.0.0",
		"@fontsource-variable/nunito": "^5.0.0",
		"@fontsource-variable/playfair-display": "^5.0.0",
		"@fontsource-variable/space-grotesk": "^5.0.0",
		"@internationalized/date": "^3.7.0",
		"@neondatabase/serverless": "^1.0.0",
		"@shikijs/rehype": "^3.0.0",
		"@threlte/core": "^8.3.1",
		"@threlte/extras": "^9.0.0",
		"@upstash/ratelimit": "^2.0.0",
		"@upstash/redis": "^1.36.0",
		"@xyflow/svelte": "^1.0.0",
		"ai": "^6.0.0",
		"better-auth": "^1.6.2",
		"bits-ui": "^2.17.3",
		"chart.js": "^4.4.0",
		"class-variance-authority": "^0.7.0",
		"clsx": "^2.1.0",
		"culori": "^4.0.0",
		"d3-dag": "^1.1.0",
		"d3-force": "^3.0.0",
		"d3-hierarchy": "^3.1.0",
		"d3-sankey": "^0.12.3",
		"d3-selection": "^3.0.0",
		"d3-zoom": "^3.0.0",
		"drizzle-orm": "^0.45.2",
		"hast-util-to-string": "^3.0.0",
		"maplibre-gl": "^5.0.0",
		"marked": "^15.0.0",
		"paneforge": "^1.0.2",
		"qrcode": "^1.5.4",
		"rehype-sanitize": "^6.0.0",
		"rehype-slug": "^6.0.0",
		"rehype-stringify": "^10.0.0",
		"remark-directive": "^4.0.0",
		"remark-extract-frontmatter": "^3.0.0",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.0",
		"remark-parse": "^11.0.0",
		"remark-rehype": "^11.0.0",
		"sanitize-html": "^2.13.0",
		"shiki": "^3.0.0",
		"svelte-maplibre-gl": "^1.0.3",
		"sveltekit-superforms": "^2.22.1",
		"three": "^0.183.2",
		"unified": "^11.0.0",
		"unist-util-visit": "^5.0.0",
		"valibot": "^1.2.0",
		"yaml": "^2.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@electric-sql/pglite": "^0.3.14",
		"@iconify-json/lucide": "^1.2.0",
		"@inlang/paraglide-js": "^2.0.0",
		"@sveltejs/adapter-vercel": "^5.0.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/culori": "^4.0.0",
		"@types/d3-force": "^3.0.0",
		"@types/d3-hierarchy": "^3.1.0",
		"@types/d3-sankey": "^0.12.0",
		"@types/d3-selection": "^3.0.0",
		"@types/d3-zoom": "^3.0.0",
		"@types/qrcode": "^1.5.5",
		"@types/sanitize-html": "^2.13.0",
		"@types/three": "^0.183.1",
		"@unocss/preset-icons": "^66",
		"@unocss/preset-uno": "^66",
		"@unocss/transformer-directives": "^66",
		"drizzle-kit": "^0.31.0",
		"knip": "^6.3.1",
		"svelte": "^5.45.6",
		"svelte-check-rs": "latest",
		"@typescript/native-preview": "latest",
		"typescript": "^5.9.3",
		"unocss": "^66",
		"vite": "^7.0.0",
		"vitest": "^4.0.0"
	}
}
