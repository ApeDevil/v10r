# Development container for SvelteKit + Bun
# Usage: podman compose up

FROM docker.io/oven/bun:1.3.12

RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Vite dev server (HMR multiplexed over the same port)
EXPOSE 5173

# Install deps and start dev server
# Dependencies installed at runtime so volume-mounted code works
CMD ["sh", "-c", "bun install && bun run dev"]
