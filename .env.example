# Database - Neon PostgreSQL
# Get connection string from: https://console.neon.tech
# MUST use the DIRECT (non-pooled) URL — no "-pooler" in hostname
# Pooled endpoint breaks drizzle-kit (PgBouncer disables SET/PREPARE)
# HTTP driver (@neondatabase/serverless) is stateless — pooling is irrelevant for app runtime
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Graph Database - Neo4j Aura
# Get credentials from: https://console.neo4j.io
NEO4J_URI="neo4j+s://xxx.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your-password"

# Cache - Upstash Redis
# Get credentials from: https://console.upstash.com
# Create a database, then copy REST URL and REST Token from the dashboard
UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AXxx..."

# Object Storage - Cloudflare R2
# Get credentials from: https://dash.cloudflare.com > Storage & Databases > R2
# Account ID: Workers & Pages > Account details (32-char hex)
# API token: R2 > Manage R2 API tokens > Create API token (Object Read & Write)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET_NAME="your-bucket-name"

# Better Auth
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:5173"

# OAuth — GitHub
# Create at: https://github.com/settings/developers > OAuth Apps > New
# Callback URL: {BETTER_AUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# OAuth — Google
# Create at: https://console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0
# Callback URL: {BETTER_AUTH_URL}/api/auth/callback/google
# Enable: Google+ API (or "Google Identity" in newer console)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OAuth — Microsoft (Azure AD / Entra ID)
# Create at: https://portal.azure.com > App registrations > New registration
# Callback URL: {BETTER_AUTH_URL}/api/auth/callback/microsoft
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"

# AI — Groq
# Create at: https://console.groq.com/keys
# Free tier: 14,400 requests/day, Llama 3.3 70B
GROQ_API_KEY="gsk_..."

# AI — OpenAI (optional)
# Create at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-..."

# AI — Google Gemini (optional)
# Create at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY="AIza..."

# AI — Provider Selection (optional, default: first configured)
# Options: groq, sai, google
AI_PROVIDER=""

# Notifications — Email (Resend)
# Create at: https://resend.com/api-keys
# Requires a verified domain for production, or use onboarding@resend.dev for testing
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="notifications@yourdomain.com"

# Notifications — Telegram
# Create a bot via @BotFather in Telegram, then register webhook:
# curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" -H "Content-Type: application/json" -d '{"url": "https://yourdomain.com/api/telegram/webhook"}'
# Local dev requires a tunnel (ngrok/cloudflared) for the webhook
TELEGRAM_BOT_TOKEN="123456:ABC-DEF..."
TELEGRAM_BOT_USERNAME="YourBotName"
# Webhook secret for verifying requests from Telegram (required in production)
# Generate with: openssl rand -base64 32
# Pass as secret_token when registering the webhook:
# curl -X POST "https://api.telegram.org/bot<TOKEN>/setWebhook" -H "Content-Type: application/json" \
#   -d '{"url": "https://yourdomain.com/api/telegram/webhook", "secret_token": "<SECRET>"}'
TELEGRAM_WEBHOOK_SECRET="generate-with-openssl-rand-base64-32"

# Notifications — Discord
# Create at: https://discord.com/developers/applications
# Bot tab: create bot, copy token. OAuth2 tab: copy client ID/secret, add redirect URI.
# Bot needs "Send Messages" permission and must share a server with the user to DM them.
DISCORD_CLIENT_ID="your-discord-client-id"
DISCORD_CLIENT_SECRET="your-discord-client-secret"
DISCORD_BOT_TOKEN="your-discord-bot-token"
DISCORD_REDIRECT_URI="http://localhost:5173/app/notifications/settings/discord/callback"

# Notifications — Encryption (required for Discord token storage)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="64-char-hex-string"

# Notifications — Delivery interval in milliseconds (default: 15000 = 15s)
DELIVERY_INTERVAL_MS=""

# Cron / Scheduled Jobs
# Secret for authenticating Vercel cron HTTP requests (must match vercel.json bearer token)
CRON_SECRET="generate-with-openssl-rand-base64-32"
# Container-mode job interval in milliseconds (default: 10800000 = 3 hours)
JOB_INTERVAL_MS=""
